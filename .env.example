# =====================================================================
# HMC / SMC Clinic Portal — environment example (P3A)
# ---------------------------------------------------------------------
# Copy to .env.local and fill with values from the Supabase dashboard.
# NEVER commit real keys. .env / .env.local are gitignored.
# The deployed frontend is NOT yet connected to Supabase (P3B will do that).
# Only the anon (publishable) key belongs in a frontend build. The
# service-role key is server-only and must NEVER appear in frontend env.
# =====================================================================

# Public project URL (safe to expose in frontend)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Anon / publishable key (safe for frontend; RLS protects data)
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLISHABLE-KEY

# Service-role key — SERVER/ADMIN ONLY. Do NOT put in any frontend bundle
# or commit to git. Used only for trusted admin tooling / migrations.
# SUPABASE_SERVICE_ROLE_KEY=DO-NOT-COMMIT
